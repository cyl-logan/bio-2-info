# ---- LLM (curation) ----
# Default: Zhipu GLM (open.bigmodel.cn). Override LLM_BASE_URL/LLM_MODEL to use
# any OpenAI-compatible endpoint (e.g. your custom Anthropic-Messages gateway
# via an OAI-shim, DeepSeek, Kimi, etc.). LLM_API_KEY takes priority over
# the legacy GLM_API_KEY name.
LLM_API_KEY=<paste-your-zhipu-or-other-llm-key-here>
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4.6

# Legacy fallback (curate.py also reads this name if LLM_API_KEY is empty)
# GLM_API_KEY=

# ---- Telegram delivery ----
# Bot token for @BotFather; chat id for your "研究资讯" channel (-100…).
TELEGRAM_BOT_TOKEN=<paste-bot-token>
TELEGRAM_CHAT_ID=-1004407117408

# ---- IMA knowledge base ----
# Where the existing ~/.config/ima/{client_id,api_key} values come from.
# In GH Actions these become repo Secrets; the ima_api.cjs reads from env or
# from $HOME/.config/ima/, so either path works.
IMA_CLIENT_ID=<paste-client-id>
IMA_API_KEY=<paste-api-key>
IMA_KB_NAME=每日生信资讯

# ---- Misc ----
# Set BIO_SKIP_IMA=1 to bypass PDF download + IMA upload (useful for local
# debugging / when running in an environment with no IMA creds).
# BIO_SKIP_IMA=1

# Optional override for the node binary (default: 'node' on PATH).
# NODE_BIN=/usr/bin/node
